# Canonical site URL, used for SEO tags (Open Graph, canonical, JSON-LD)
VITE_SITE_URL=https://studypark.edu.np

# WhatsApp number for the floating chat button (international format, no + or spaces)
VITE_WHATSAPP_NUMBER=97714417168

# Optional: endpoint the contact form posts to. If unset, the form falls back
# to a mailto link so the site still works with zero backend.
VITE_CONTACT_ENDPOINT=
